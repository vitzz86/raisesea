# ── GEMINI (NEW in v2) ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Get from: https://aistudio.google.com/app/apikey (free)

# ── DEEPSEEK (NEWS PIPELINE) ───────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Optional override; default is https://api.deepseek.com/chat/completions
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# ── SUPABASE ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── GOOGLE DRIVE ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id

# ── APP ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://raisesea.onrender.com
ADMIN_SECRET_KEY=choose_a_strong_secret_key

